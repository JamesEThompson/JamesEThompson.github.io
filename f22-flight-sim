      aspect-ratio: 16/9;
    }
    .video-embed iframe {
      width: 100%; height: 100%;
      border: none;
      display: block;
    }
    */
 
    /* ── HARDWARE TABLE ── */
    .hw-table {
      width: 100%;
      border-collapse: collapse;
      font-family: 'Share Tech Mono', monospace;
      font-size: 13px;
    }
    .hw-table th {
      text-align: left;
      padding: 10px 16px;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
      font-weight: 400;
      letter-spacing: 0.08em;
      font-size: 11px;
      text-transform: uppercase;
    }
    .hw-table td {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(26,47,74,0.5);
      color: var(--text);
    }
    .hw-table tr:last-child td { border-bottom: none; }
    .hw-table tr:hover td { background: rgba(0,200,255,0.03); }
    .hw-table .pin { color: var(--accent); }
    .hw-table .hard { color: var(--accent2); }
    .hw-table .soft { color: var(--green); }
 
    /* ── TASK TABLE ── */
    .task-grid {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .task-row {
      display: grid;
      grid-template-columns: 160px 60px 80px 80px 1fr;
      gap: 16px;
      align-items: center;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 14px 20px;
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      transition: border-color 0.2s;
    }
    .task-row:hover { border-color: var(--accent); }
    .task-row.header {
      background: transparent;
      border-color: transparent;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding-bottom: 4px;
    }
    .task-name { color: #fff; font-weight: 700; }
    .task-pri  { color: var(--accent); text-align: center; }
    .task-period { color: var(--text); }
    .task-type.hard { color: var(--accent2); }
    .task-type.soft { color: var(--green); }
    .task-desc { color: var(--muted); font-size: 11px; }
    @media (max-width: 700px) {
      .task-row { grid-template-columns: 1fr 1fr; }
      .task-row.header { display: none; }
    }
 
    /* ── FOOTER ── */
    footer {
      position: relative; z-index: 1;
      border-top: 1px solid var(--border);
      padding: 32px 40px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    footer p {
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--muted);
    }
    .footer-links { display: flex; gap: 24px; }
    .footer-links a {
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      color: var(--muted);
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-links a:hover { color: var(--accent); }
 
    /* ── LED BLINK ANIMATION (decorative) ── */
    .led-demo {
      display: flex; gap: 16px; align-items: center;
      margin-bottom: 32px;
    }
    .led {
      width: 14px; height: 14px; border-radius: 50%;
    }
    .led.green {
      background: var(--green);
      box-shadow: 0 0 10px var(--green);
      animation: blink-gun 0.1s step-end infinite;
    }
    .led.red {
      background: var(--accent2);
      box-shadow: 0 0 10px var(--accent2);
      animation: blink-alt 1.2s ease-in-out infinite;
    }
    .led-label {
      font-family: 'Share Tech Mono', monospace;
      font-size: 11px;
      color: var(--muted);
      letter-spacing: 0.08em;
    }
    @keyframes blink-gun {
      0%,49% { opacity: 1; }
      50%,100% { opacity: 0.1; }
    }
    @keyframes blink-alt {
      0%,100% { opacity: 1; }
      50%      { opacity: 0.2; }
    }
  </style>
</head>
